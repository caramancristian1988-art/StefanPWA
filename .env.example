# ----------------------------------------------------------------------------
# Bază de date — MongoDB (Prisma necesită un replica set pentru tranzacții)
# Local: rulează MongoDB ca replica set, sau folosește MongoDB Atlas.
# Exemplu local:   mongodb://127.0.0.1:27017/programari?replicaSet=rs0
# Exemplu Atlas:   mongodb+srv://user:parola@cluster0.abcde.mongodb.net/programari?retryWrites=true&w=majority
# ----------------------------------------------------------------------------
DATABASE_URL="mongodb://127.0.0.1:27017/programari?replicaSet=rs0"

# ----------------------------------------------------------------------------
# Auth / sesiune
# Generează cu: openssl rand -base64 32
# Exemplu: 0od04tg6rU4GdGpRjSOkzhRycrCayIweTq/aiO454d0=
# ----------------------------------------------------------------------------
SESSION_SECRET="schimba-ma-cu-un-secret-lung-random"
SESSION_COOKIE_NAME="pr_session"
# Durata sesiunii în zile (cerință: foarte lung)
SESSION_TTL_DAYS="180"

# URL public al aplicației (pentru webhook Telegram, linkuri în email, PWA)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ----------------------------------------------------------------------------
# Telegram Bot
# Token de la @BotFather. WEBHOOK_SECRET = string random pe care îl trimitem ca
# secret_token la setarea webhook-ului și îl verificăm la fiecare request.
# Exemplu token:   123456789:AAFa1b2C3dE4fG5hI6jK7lM8nO9pQ0rStUv
# Exemplu secret:  YqYhz_SxnsjuoooctMf96kV8_xDxFfbp  (generat cu: openssl rand -base64 24)
# ----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=""
TELEGRAM_WEBHOOK_SECRET=""

# ----------------------------------------------------------------------------
# Cron — protejează ruta /api/cron/reminders. Trimite ca header:
#   Authorization: Bearer <CRON_SECRET>
# Exemplu: gKrlzOoz0LRpTZbLD7iPWiuSKtI-D87C  (generat cu: openssl rand -base64 24)
# ----------------------------------------------------------------------------
CRON_SECRET="schimba-ma"

# ----------------------------------------------------------------------------
# Email (Nodemailer SMTP) — reminder opțional
# Exemplu Gmail:    SMTP_HOST="smtp.gmail.com"  SMTP_PORT="587"  SMTP_USER="numele.tau@gmail.com"
#                   SMTP_PASS="abcd efgh ijkl mnop"  (App Password, NU parola normală de Gmail)
# Exemplu generic:  SMTP_HOST="smtp.mailtrap.io"  SMTP_USER="a1b2c3d4e5f6g7"  SMTP_PASS="h8i9j0k1l2m3n4"
# ----------------------------------------------------------------------------
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"        # true pentru portul 465
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="Programări <no-reply@example.com>"

# ----------------------------------------------------------------------------
# AI voice-to-task
# Transcriere: endpoint OpenAI-compatibil (Whisper). Extragere: model prin AI SDK.
# Exemplu key: sk-proj-AbCdEfGhIjKlMnOpQrStUvWxYz1234567890AbCdEfGhIj
# ----------------------------------------------------------------------------
OPENAI_API_KEY=""
AI_TRANSCRIBE_MODEL="whisper-1"
AI_PARSE_MODEL="gpt-4o-mini"

# ----------------------------------------------------------------------------
# PWA Web Push (opțional) — generează cu: npx web-push generate-vapid-keys
# Exemplu public:  BDjVkYGAbeusF-0hDS4dH0QbOaHWfe3hsMlG0WHOJkYSlq98UbyugT_M_ig_lGenLZdfwBQUpAI0UdQKInHO2QE
# Exemplu privat:  rYrQghf3NJgW2K9uagFFXOv8pJtRxT11pzLoqy6hlvQ
# ----------------------------------------------------------------------------
NEXT_PUBLIC_MAPBOX_TOKEN=""

NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@example.com"

# ----------------------------------------------------------------------------
# Vercel Blob — stocare fișiere atașate la task-uri (poze, PDF-uri)
# Obții din: vercel.com → proiect → Storage → Blob → tab ".env.local"
# Exemplu: vercel_blob_rw_AbCdEfGhIjKlMn_aBcDeFgHiJkLmNoPqRsTuVwXyZ1234567890
# ----------------------------------------------------------------------------
BLOB_READ_WRITE_TOKEN=""
