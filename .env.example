# ----------------------------------------------------------------------------
# Bază de date — MongoDB (Prisma necesită un replica set pentru tranzacții)
# Local: rulează MongoDB ca replica set, sau folosește MongoDB Atlas.
# ----------------------------------------------------------------------------
DATABASE_URL="mongodb://127.0.0.1:27017/programari?replicaSet=rs0"

# ----------------------------------------------------------------------------
# Auth / sesiune
# Generează cu: openssl rand -base64 32
# ----------------------------------------------------------------------------
SESSION_SECRET="schimba-ma-cu-un-secret-lung-random"
SESSION_COOKIE_NAME="pr_session"
# Durata sesiunii în zile (cerință: foarte lung)
SESSION_TTL_DAYS="180"

# URL public al aplicației (pentru webhook Telegram, linkuri în email, PWA)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ----------------------------------------------------------------------------
# Telegram Bot
# Token de la @BotFather. WEBHOOK_SECRET = string random pe care îl trimitem ca
# secret_token la setarea webhook-ului și îl verificăm la fiecare request.
# ----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=""
TELEGRAM_WEBHOOK_SECRET=""

# ----------------------------------------------------------------------------
# Cron — protejează ruta /api/cron/reminders. Trimite ca header:
#   Authorization: Bearer <CRON_SECRET>
# ----------------------------------------------------------------------------
CRON_SECRET="schimba-ma"

# ----------------------------------------------------------------------------
# Email (Nodemailer SMTP) — reminder opțional
# ----------------------------------------------------------------------------
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"        # true pentru portul 465
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="Programări <no-reply@example.com>"

# ----------------------------------------------------------------------------
# AI voice-to-task
# Transcriere: endpoint OpenAI-compatibil (Whisper). Extragere: model prin AI SDK.
# ----------------------------------------------------------------------------
OPENAI_API_KEY=""
AI_TRANSCRIBE_MODEL="whisper-1"
AI_PARSE_MODEL="gpt-4o-mini"

# ----------------------------------------------------------------------------
# PWA Web Push (opțional) — generează cu: npx web-push generate-vapid-keys
# ----------------------------------------------------------------------------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@example.com"
